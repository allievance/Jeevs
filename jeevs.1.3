#!/usr/bin/env bash

echo "Jeevs starting... $(pwd)"
set -x

# ========================================

# JEEVS 1.3 - dialogic shell OS layer

# ========================================

echo "At your service."

# ----------------------------------------
# FUNCTIONS
# ----------------------------------------

# Builtin / dialogic interpreter

jeevs_interpret() {
	local phrase="$1"

	case "$phrase" in
		*where\ am\ i* ) pwd ;;
		*what\ failed* ) echo "Last command failed, reason unknown" ;;
		*help* ) echo "I can execute commands or respond to natural language" ;;
		* ) echo "I do not understand '$phrase'" ;;
	esac
}

# Classifier: is this a raw shell command?

jeevs_is_shell() {
	local cmd="${1%% *}"
	command -v "$cmd" >/dev/null 2>&1
}

# -----------------------------------------
# MAIN LOOP
# -----------------------------------------

# Input

while true; do
	read -p "jeevs>" input || continue

# Trim whitespace

input="${input#"${input%%[![:space:]]*}"}"
input="${input%"${input##*[![:space:]]}"}"

# Skim empty input

[[ -z "$input" ]] && continue

# -----------------------------------------
# ESCAPE HATCH
# -----------------------------------------

if [[ "$input" == "exit" ]]; then
	echo "Goodbye."
	break

# -----------------------------------------
# BUILTINS
# -----------------------------------------

if [[ "$input" == cd* ]]; then
	target="${input#cd }"

	if [[ -z "$target" || "$target" == "cd" ]]; then
		cd ~ || echo "I'm sorry. I cannot change directories."
	else
		cd "$target" || echo "I'm sorry. There is no such directory."
	fi

continue
fi

# ------------------------------------------
# ROUTING
# ------------------------------------------

if jeevs_is_shell "$input"; then
	# Raw shell commands: execut, suppress raw stderr
	bash -c "$input" 2>/dev/null
else
	# Natural language: pass to interpreter
	jeevs_interpret "$input"
fi
done
